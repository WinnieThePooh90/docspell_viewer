<?xml version="1.0" encoding="utf-8"?>
<!--
  Cloud backup and device-to-device transfer: same policy as backup_rules.xml.
  Passwords excluded; everything else included.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
        <exclude domain="sharedpref" path="docspell_account_secrets.xml" />
        <exclude domain="sharedpref" path="docspell_server_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
        <exclude domain="sharedpref" path="docspell_account_secrets.xml" />
        <exclude domain="sharedpref" path="docspell_server_settings.xml" />
    </device-transfer>
</data-extraction-rules>
